{
  "name": "opencode-memento",
  "version": "1.0.0",
  "description": "Preserves project context across OpenCode sessions by injecting relevant prior work into compaction",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsc && bun build ./src/index.ts --outdir ./dist --target bun",
    "dev": "bun run --watch ./src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "session",
    "context",
    "compaction",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awdemos/opencode-memento.git"
  },
  "bugs": {
    "url": "https://github.com/awdemos/opencode-memento/issues"
  },
  "homepage": "https://github.com/awdemos/opencode-memento#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": ">=0.1.0",
    "bun-types": "latest",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
